#!/usr/bin/env bash
# Deckard claude wrapper - injects hooks and session tracking

find_real_claude() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/claude" ]] && printf '%s' "$d/claude" && return 0
    done
    return 1
}

if [[ -z "$DECKARD_SURFACE_ID" || "$DECKARD_HOOKS_DISABLED" == "1" ]]; then
    REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }
    exec "$REAL_CLAUDE" "$@"
fi

REAL_CLAUDE="$(find_real_claude)" || { echo "Error: claude not found in PATH" >&2; exit 127; }

case "${1:-}" in
    mcp|config|api-key) exec "$REAL_CLAUDE" "$@" ;;
esac

unset CLAUDECODE

HAS_RESUME=false
for arg in "$@"; do
    case "$arg" in
        --resume|--resume=*|--continue|-c)
            HAS_RESUME=true
            break
            ;;
    esac
done

SURFACE_ID="$DECKARD_SURFACE_ID"
SOCKET_PATH="$DECKARD_SOCKET_PATH"
CWD="$(pwd)"
HOOK_HELPER="/tmp/deckard-hook-${SURFACE_ID}.sh"

# Encode the CWD like Claude does: /Users/foo/bar → -Users-foo-bar
ENCODED_CWD=$(echo "$CWD" | sed 's|/|-|g')

cat > "$HOOK_HELPER" << HOOKEOF
#!/bin/bash
EVENT="\$1"
SURFACE="$SURFACE_ID"
SOCKET="$SOCKET_PATH"
[[ -z "\$SOCKET" || ! -S "\$SOCKET" ]] && exit 0

EXTRA=""
if [[ "\$EVENT" == "session-start" ]]; then
    # Find the session ID from the most recently modified JSONL in this project
    PROJECT_DIR="\$HOME/.claude/projects/$ENCODED_CWD"
    if [[ -d "\$PROJECT_DIR" ]]; then
        NEWEST=\$(ls -t "\$PROJECT_DIR"/*.jsonl 2>/dev/null | head -1)
        if [[ -n "\$NEWEST" ]]; then
            SID=\$(basename "\$NEWEST" .jsonl)
            EXTRA=",\"sessionId\":\"\$SID\""
        fi
    fi
fi

printf '{"command":"hook.%s","surfaceId":"%s"%s}\n' "\$EVENT" "\$SURFACE" "\$EXTRA" | nc -U "\$SOCKET" -w 1 2>/dev/null
HOOKEOF
chmod +x "$HOOK_HELPER"

HOOKS_JSON="{\"hooks\":{\"SessionStart\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$HOOK_HELPER session-start\",\"timeout\":10}]}],\"Stop\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$HOOK_HELPER stop\",\"timeout\":10}]}],\"Notification\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$HOOK_HELPER notification\",\"timeout\":10}]}],\"UserPromptSubmit\":[{\"matcher\":\"\",\"hooks\":[{\"type\":\"command\",\"command\":\"$HOOK_HELPER user-prompt-submit\",\"timeout\":10}]}]}}"

exec "$REAL_CLAUDE" --settings "$HOOKS_JSON" "$@"
