#!/bin/bash
# Pre-commit hook: runs SwiftLint on staged Swift files.
# Install: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit

SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift')

if [ -z "$SWIFT_FILES" ]; then
    exit 0
fi

if ! command -v swiftlint &>/dev/null; then
    echo "warning: swiftlint not installed, skipping lint (brew install swiftlint)"
    exit 0
fi

echo "$SWIFT_FILES" | xargs swiftlint lint --strict --quiet
